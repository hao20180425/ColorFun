/* =====================================================================
 * 设计语言：柔粉糖果 × 紫调主视觉
 *   - 主色：紫 #7b61ff（强调 / Logo / Banner 渐变）
 *   - 背景：#f7f7fb 极浅紫灰，干净、温柔
 *   - 卡片：白底 + 大圆角 + 轻投影
 *   - 字体：PingFang SC 优先，带圆润字重对比
 * ===================================================================== */
/* ---------- 设计变量 ---------- */
/* ---------- 页面根容器 ---------- */
.home-page.data-v-83a5a03c {
  width: 100%;
  min-height: 100vh;
  background: #f7f7fb;
  font-family: "PingFang SC", "PingFangSC-Regular", "Hiragino Sans GB", sans-serif;
  color: #1f1f2c;
  /* scroll-view 在某些机型上需要显式高度 */
  height: 100vh;
  box-sizing: border-box;
}

/* =====================================================================
 * 1) 顶部 Logo 区
 * ===================================================================== */
.hero-header.data-v-83a5a03c {
  position: relative;
  padding: 80rpx 40rpx 30rpx;
  /* 状态栏占位（沉浸式自定义导航栏下，安全区由系统留出） */
  padding-top: calc(80rpx + constant(safe-area-inset-top));
  padding-top: calc(80rpx + env(safe-area-inset-top));
}
.hero-header .hero-logo.data-v-83a5a03c {
  display: block;
  font-size: 64rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  line-height: 1.1;
  /* 紫色渐变文字（背景裁剪） */
  background: linear-gradient(135deg, #7b61ff 0%, #b58dff 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: #7b61ff; /* 兼容老内核 */
}
.hero-header .hero-subtitle.data-v-83a5a03c {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #8a8aa3;
  letter-spacing: 4rpx;
}
.hero-header.data-v-83a5a03c {
  /* 装饰星星：小尺寸 + 微旋转 */
}
.hero-header .hero-deco.data-v-83a5a03c {
  position: absolute;
  font-size: 36rpx;
  line-height: 1;
  opacity: 0.85;
}
.hero-header .hero-deco-star1.data-v-83a5a03c {
  top: calc(60rpx + env(safe-area-inset-top));
  right: 60rpx;
  transform: rotate(12deg);
}
.hero-header .hero-deco-star2.data-v-83a5a03c {
  top: calc(120rpx + env(safe-area-inset-top));
  right: 130rpx;
  font-size: 24rpx;
  transform: rotate(-18deg);
  opacity: 0.6;
}

/* =====================================================================
 * 2) Banner 大卡片
 * ===================================================================== */
.banner.data-v-83a5a03c {
  position: relative;
  margin: 20rpx 32rpx 0;
  padding: 48rpx 40rpx;
  border-radius: 30rpx;
  overflow: hidden;
  /* 紫色多段渐变背景 */
  background: linear-gradient(135deg, #7b61ff 0%, #9d8bff 55%, #b89dff 100%);
  box-shadow: 0 16rpx 36rpx rgba(123, 97, 255, 0.28);
  color: #ffffff;
  min-height: 220rpx;
}

/* Banner 内的两个柔和大圆点（背景装饰） */
.banner-blob.data-v-83a5a03c {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(2rpx);
}
.banner-blob-1.data-v-83a5a03c {
  top: -60rpx;
  right: -40rpx;
  width: 220rpx;
  height: 220rpx;
  background: rgba(255, 255, 255, 0.18);
}
.banner-blob-2.data-v-83a5a03c {
  bottom: -80rpx;
  left: -60rpx;
  width: 260rpx;
  height: 260rpx;
  background: rgba(255, 255, 255, 0.1);
}
.banner-content.data-v-83a5a03c {
  position: relative;
  z-index: 1;
}
.banner-content .banner-title.data-v-83a5a03c {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  line-height: 1.3;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.08);
}
.banner-content .banner-desc.data-v-83a5a03c {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  font-weight: 400;
  letter-spacing: 1rpx;
  opacity: 0.92;
}

/* Banner 标语下的彩色小圆点装饰 */
.banner-dots.data-v-83a5a03c {
  display: flex;
  gap: 12rpx;
  margin-top: 22rpx;
}
.banner-dots .banner-dot.data-v-83a5a03c {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

/* Banner 右上角的大 emoji 装饰 */
.banner-emoji.data-v-83a5a03c {
  position: absolute;
  right: 32rpx;
  bottom: 32rpx;
  font-size: 96rpx;
  line-height: 1;
  opacity: 0.85;
  transform: rotate(-12deg);
  z-index: 1;
}

/* =====================================================================
 * 3) 区块标题：✨ 选择线稿 ✨ / 💖 热门推荐 💖
 * ===================================================================== */
.section-title.data-v-83a5a03c {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin: 56rpx 32rpx 24rpx;
}
.section-title .section-text.data-v-83a5a03c {
  font-size: 32rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  color: #1f1f2c;
}
.section-title .section-deco.data-v-83a5a03c {
  font-size: 28rpx;
  line-height: 1;
}

/* =====================================================================
 * 4) 双栏入口卡片
 * ===================================================================== */
.entry-grid.data-v-83a5a03c {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin: 0 32rpx;
}
.entry-card.data-v-83a5a03c {
  position: relative;
  padding: 36rpx 32rpx;
  border-radius: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(123, 97, 255, 0.06);
  min-height: 200rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  transition: transform 0.18s ease, box-shadow 0.18s ease;
  overflow: hidden;
}
.entry-card .entry-emoji.data-v-83a5a03c {
  font-size: 56rpx;
  line-height: 1;
  margin-bottom: 18rpx;
}
.entry-card .entry-title.data-v-83a5a03c {
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  margin-bottom: 8rpx;
}
.entry-card .entry-desc.data-v-83a5a03c {
  font-size: 22rpx;
  color: #8a8aa3;
  letter-spacing: 1rpx;
}
.entry-card .entry-arrow.data-v-83a5a03c {
  position: absolute;
  right: 32rpx;
  bottom: 32rpx;
  font-size: 32rpx;
  font-weight: 700;
  opacity: 0.6;
}
.entry-card.data-v-83a5a03c:active {
  transform: translateY(2rpx) scale(0.98);
  box-shadow: 0 4rpx 14rpx rgba(123, 97, 255, 0.06);
}

/* 相册卡：浅蓝 #e9f3ff，标题蓝色 */
.entry-card-album.data-v-83a5a03c {
  background: #e9f3ff;
}
.entry-card-album .entry-title-album.data-v-83a5a03c {
  color: #2f7adb;
}
.entry-card-album .entry-arrow.data-v-83a5a03c {
  color: #2f7adb;
}

/* 内置卡：浅黄 #fff3d8，标题橙色 */
.entry-card-builtin.data-v-83a5a03c {
  background: #fff3d8;
}
.entry-card-builtin .entry-title-builtin.data-v-83a5a03c {
  color: #e2912a;
}
.entry-card-builtin .entry-arrow.data-v-83a5a03c {
  color: #e2912a;
}

/* =====================================================================
 * 6) 3 列线稿缩略图网格
 *    用 grid 实现等宽 + 等间距
 * ===================================================================== */
.lineart-grid.data-v-83a5a03c {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin: 0 32rpx;
}
.lineart-card.data-v-83a5a03c {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 6rpx 18rpx rgba(31, 31, 44, 0.05);
  transition: transform 0.18s ease;
}
.lineart-card.data-v-83a5a03c:active {
  transform: scale(0.95);
}
.lineart-thumb.data-v-83a5a03c {
  width: 100%;
  aspect-ratio: 1/1;
  /* aspect-ratio 在小程序中部分基础库不支持，叠加 padding-top 兆底 */
  padding-top: 100%;
  position: relative;
  background: #ffffff;
  border-radius: 18rpx;
  overflow: hidden;
}
.lineart-thumb .lineart-thumb-img.data-v-83a5a03c {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}
.lineart-thumb .lineart-thumb-fallback.data-v-83a5a03c {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: repeating-linear-gradient(45deg, #efeff5, #efeff5 8rpx, #e5e5ee 8rpx, #e5e5ee 16rpx);
}
.lineart-thumb .lineart-thumb-fallback .fallback-emoji.data-v-83a5a03c {
  font-size: 48rpx;
  opacity: 0.55;
}
.lineart-name.data-v-83a5a03c {
  margin-top: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #1f1f2c;
  letter-spacing: 1rpx;
}

/* =====================================================================
 * 7) 底部装饰文字
 * ===================================================================== */
.footer-deco.data-v-83a5a03c {
  margin: 60rpx 32rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.footer-deco .footer-text.data-v-83a5a03c {
  font-size: 26rpx;
  font-weight: 600;
  color: #8a8aa3;
  letter-spacing: 4rpx;
}

/* 底部安全区占位 */
.safe-bottom.data-v-83a5a03c {
  height: calc(40rpx + constant(safe-area-inset-bottom));
  height: calc(40rpx + env(safe-area-inset-bottom));
}