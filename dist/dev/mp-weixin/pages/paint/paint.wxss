/* 主题色 */
/* 字体 */
/* 安全区域 */
/* ============ 页面容器 ============ */
.paint-page.data-v-d0d3b748 {
  min-height: 100vh; /* 最小满屏，内容超出则自然延伸，不产生底部空白 */
  background: #f7f7fb;
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
  box-sizing: border-box;
}

/* ============ 胶囊行：返回 + 标题，与胶囊等高 ============ */
.nav-row.data-v-d0d3b748 {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding-left: 24rpx;
  box-sizing: border-box;
  /* height 和 paddingRight 由 JS 动态设置 */
}

/* 左侧：返回按钮 + 标题 */
.top-bar-left.data-v-d0d3b748 {
  display: flex;
  flex-direction: row;
  align-items: center;
}
.back.data-v-d0d3b748 {
  width: 70rpx;
  height: 70rpx;
  background: #eee7ff;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.back-icon.data-v-d0d3b748 {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1;
  color: #7b61ff;
  margin-top: -4rpx;
}
.title.data-v-d0d3b748 {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f1b3a;
  margin-left: 20rpx;
}

/* ============ 按钮行：清空 + 保存，在胶囊下方右对齐 ============ */
.action-row.data-v-d0d3b748 {
  display: flex;
  flex-direction: row;
  justify-content: flex-end; /* 向右对齐 */
  align-items: flex-start;
  padding: 20rpx 0 24rpx;
  box-sizing: border-box;
  /* paddingRight 由 JS 动态设置，对齐胶囊右边 */
}

/* 单个竖排图标按钮 */
.action-btn.data-v-d0d3b748 {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 20rpx;
}

/* 图标圆角方块 */
.action-icon-box.data-v-d0d3b748 {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.clear-box.data-v-d0d3b748 {
  background: #ffe6e6;
}
.save-box.data-v-d0d3b748 {
  background: #eee7ff;
}
.action-icon.data-v-d0d3b748 {
  font-size: 40rpx;
  line-height: 1;
}
.action-label.data-v-d0d3b748 {
  font-size: 24rpx;
  margin-top: 8rpx;
  font-weight: 500;
}
.clear-label.data-v-d0d3b748 {
  color: #ff4d4f;
}
.save-label.data-v-d0d3b748 {
  color: #7b61ff;
}
.hover-light.data-v-d0d3b748 {
  opacity: 0.7;
}

/* ============ 画布卡片 ============ */
.canvas-box.data-v-d0d3b748 {
  height: 50vh;
  margin: 20rpx 24rpx;
  background: #ffffff;
  border-radius: 40rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 8rpx 32rpx rgba(123, 97, 255, 0.08);
}
.canvas.data-v-d0d3b748 {
  width: 100%;
  height: 100%;
  display: block;
}

/* ============ 模式切换栏 ============ */
.mode-bar.data-v-d0d3b748 {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
  padding: 16rpx 0 12rpx;
}
.mode-btn.data-v-d0d3b748 {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  width: 200rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin: 0 8rpx;
  background: #ffffff;
  color: #888888;
  border: 2rpx solid #e0e0e8;
  box-sizing: border-box;
}
.mode-btn.active.data-v-d0d3b748 {
  background: #7b61ff;
  color: #ffffff;
  border-color: #7b61ff;
  box-shadow: 0 8rpx 20rpx rgba(123, 97, 255, 0.3);
}
.mode-icon.data-v-d0d3b748 {
  font-size: 32rpx;
  margin-right: 8rpx;
  line-height: 1;
}
.mode-text.data-v-d0d3b748 {
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
}

/* ============ 颜色面板 ============ */
.color-panel.data-v-d0d3b748 {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: space-around;
  padding: 16rpx 24rpx 4rpx;
}

/* 88rpx 大圆圈色块，对齐设计图 */
.color-item.data-v-d0d3b748 {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 24rpx;
  box-sizing: border-box;
}
.color-item.active.data-v-d0d3b748 {
  border-color: #7b61ff;
  transform: scale(1.15);
  box-shadow: 0 6rpx 18rpx rgba(123, 97, 255, 0.4);
}

/* ============ 线宽滑块 ============ */
.slider-box.data-v-d0d3b748 {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin: 4rpx 32rpx 24rpx;
  padding: 12rpx 24rpx;
  background: #ffffff;
  border-radius: 30rpx;
}
.slider-label.data-v-d0d3b748 {
  font-size: 26rpx;
  color: #666666;
  margin-right: 12rpx;
  flex-shrink: 0;
}
.slider.data-v-d0d3b748 {
  flex: 1;
  margin: 0 8rpx;
}
.slider-value.data-v-d0d3b748 {
  font-size: 26rpx;
  color: #7b61ff;
  font-weight: 600;
  min-width: 40rpx;
  text-align: right;
}