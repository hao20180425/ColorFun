/* 全局 SCSS 变量 */
/* 主题色 */
/* 字体 */
/* 安全区域 */
/* =====================================================================
 * 设计语言：与首页/绘画页保持一致
 *   - 主色：#7b61ff
 *   - 背景：#f7f7fb
 *   - 卡片：白底 + 大圆角
 * ===================================================================== */
page.data-v-baf60e71 {
  background: #f7f7fb;
}
.page.data-v-baf60e71 {
  min-height: 100vh;
  padding: 0 24rpx 24rpx;
  box-sizing: border-box;
  background: #f7f7fb;
  font-family: "PingFang SC", "PingFangSC-Regular", sans-serif;
}

/* ---------- 顶部胶囊行 ---------- */
.header.data-v-baf60e71 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  /* height / paddingRight 由 headerStyle 动态注入 */
}
.left-box.data-v-baf60e71 {
  display: flex;
  align-items: center;
  height: 100%;
}
.back.data-v-baf60e71 {
  width: 64rpx;
  height: 64rpx;
  background: #efe8ff;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7b61ff;
}
.back .back-icon.data-v-baf60e71 {
  font-size: 44rpx;
  line-height: 1;
  font-weight: 700;
  margin-top: -4rpx;
}
.hover-light.data-v-baf60e71 {
  opacity: 0.7;
}
.title.data-v-baf60e71 {
  font-size: 36rpx;
  font-weight: 800;
  margin-left: 20rpx;
  color: #1f1f2c;
  letter-spacing: 1rpx;
}

/* ---------- 搜索框 ---------- */
.search-box.data-v-baf60e71 {
  height: 80rpx;
  background: #ffffff;
  border-radius: 40rpx;
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  box-shadow: 0 4rpx 14rpx rgba(123, 97, 255, 0.05);
}
.search-box .search-icon.data-v-baf60e71 {
  font-size: 30rpx;
  color: #aaa;
}
.search-box .search-input.data-v-baf60e71 {
  flex: 1;
  margin-left: 16rpx;
  font-size: 26rpx;
  color: #1f1f2c;
}
.search-box .search-ph.data-v-baf60e71 {
  color: #b8b8c8;
}

/* ---------- 顶部 Tab ---------- */
.top-tabs.data-v-baf60e71 {
  display: flex;
  align-items: center;
  margin-top: 26rpx;
}
.top-tab.data-v-baf60e71 {
  min-width: 132rpx;
  height: 64rpx;
  padding: 0 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  text-align: center;
  line-height: 64rpx;
  font-size: 26rpx;
  margin-right: 16rpx;
  font-weight: 600;
  color: #1f1f2c;
}
.top-tab.active.data-v-baf60e71 {
  background: #7b61ff;
  color: #fff;
  box-shadow: 0 6rpx 18rpx rgba(123, 97, 255, 0.28);
}
.layout-btn.data-v-baf60e71 {
  margin-left: auto;
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: #ffffff;
  text-align: center;
  line-height: 64rpx;
  font-size: 32rpx;
  color: #7b61ff;
}

/* ---------- 主体：左侧 + 右侧 ---------- */
.content.data-v-baf60e71 {
  display: flex;
  margin-top: 24rpx;
  /* 视口高度 - 顶部各区域估算高度，保证两侧 scroll-view 有高度 */
  height: calc(100vh - 320rpx);
}

/* 左侧分类菜单 */
.sidebar.data-v-baf60e71 {
  width: 150rpx;
  flex-shrink: 0;
  height: 100%;
}
.menu-item.data-v-baf60e71 {
  height: 80rpx;
  line-height: 80rpx;
  padding-left: 16rpx;
  font-size: 26rpx;
  color: #666;
  border-radius: 18rpx;
  margin-bottom: 10rpx;
}
.menu-item.active.data-v-baf60e71 {
  background: #efe8ff;
  color: #7b61ff;
  font-weight: bold;
}

/* 右侧线稿网格 */
.draft-scroll.data-v-baf60e71 {
  flex: 1;
  height: 100%;
  margin-left: 12rpx;
}
.draft-grid.data-v-baf60e71 {
  display: flex;
  flex-wrap: wrap;
  /* 左对齐排列，避免少量卡片时 space-between 导致两端分散 */
  justify-content: flex-start;
  gap: 16rpx;
  padding: 0 4rpx;
}
.draft-card.data-v-baf60e71 {
  width: 31.5%;
  background: #ffffff;
  border-radius: 22rpx;
  overflow: hidden;
  margin-bottom: 4rpx;
  position: relative;
  padding-bottom: 14rpx;
  box-shadow: 0 4rpx 12rpx rgba(31, 31, 44, 0.04);
  transition: transform 0.18s ease;
}
.card-hover.data-v-baf60e71 {
  transform: scale(0.96);
}
.draft-thumb.data-v-baf60e71 {
  width: 100%;
  height: 200rpx;
  background: #f4f4fa;
  position: relative;
  overflow: hidden;
}
.draft-thumb .draft-img.data-v-baf60e71 {
  width: 100%;
  height: 100%;
}
.draft-thumb .draft-fallback.data-v-baf60e71 {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: repeating-linear-gradient(45deg, #efeff5, #efeff5 8rpx, #e5e5ee 8rpx, #e5e5ee 16rpx);
}
.draft-thumb .draft-fallback .fallback-emoji.data-v-baf60e71 {
  font-size: 48rpx;
  opacity: 0.55;
}
.draft-name.data-v-baf60e71 {
  font-size: 24rpx;
  padding: 0 14rpx;
  margin-top: 10rpx;
  color: #1f1f2c;
  font-weight: 600;
}
.heart.data-v-baf60e71 {
  position: absolute;
  right: 14rpx;
  bottom: 12rpx;
  font-size: 26rpx;
  color: #c8c8d4;
}
.empty-tip.data-v-baf60e71 {
  text-align: center;
  color: #8a8aa3;
  font-size: 26rpx;
  padding: 60rpx 0 30rpx;
}
.footer-tip.data-v-baf60e71 {
  text-align: center;
  color: #b39cff;
  font-size: 24rpx;
  padding: 24rpx 0 60rpx;
  letter-spacing: 2rpx;
}